<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>The core transaction object. One record per credential requirement per person or organisation. Tracks the full lifecycle from the admin requesting a submission through volunteer intake, admin verification, and eventual expiry. OWD is Private - volunteers cannot see each other&apos;s records.</description>
    <deploymentStatus>Deployed</deploymentStatus>
    <!-- History tracking is enabled to support the Field History Tracking requirement on Sighted__c (task 1.18). -->
    <enableHistory>true</enableHistory>
    <label>Credential</label>
    <nameField>
        <displayFormat>CR-{0000}</displayFormat>
        <label>Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Credentials</pluralLabel>
    <!-- Private OWD enforces that volunteers cannot see each other&apos;s credential records, even if they somehow access the Experience Cloud site as an authenticated user. See docs/security.md. -->
    <sharingModel>Private</sharingModel>
    <compactLayoutAssignment>Credential_Highlights</compactLayoutAssignment>
</CustomObject>
